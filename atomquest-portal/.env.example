# ============================================
# AtomQuest Portal - Environment Configuration
# ============================================

# Database
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/atomquest

# For MongoDB Atlas (cloud - recommended):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/atomquest?retryWrites=true&w=majority

# Server
PORT=5000
NODE_ENV=development

# Client
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-key-change-me-in-production-12345

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@atomquest.com

# App
APP_NAME=AtomQuest Portal
APP_VERSION=1.0.0
